# Plik File Sharing - Environment Configuration (Development)
# SSOT: /opt/.github/COPILOT-INSTRUCTIONS.md

# Server Configuration
PLIK_SERVER_LISTENADDR=0.0.0.0:8080

# Upload Limits
PLIK_MAX_FILE_SIZE=102400          # Max file size in MB (100 MB)
PLIK_MAX_TTL=2592000               # Max TTL in seconds (30 days)

# Storage
PLIK_DATA_DIR=/plik/data

# Public URL (development)
PUBLIC_URL=http://localhost:8085

# Optional: Authentication (pokiaľ chceš povoliť login)
# PLIK_AUTHENTICATION=true
# PLIK_AUTHENTICATION_PROVIDER=local

# Optional: Rate Limiting
# PLIK_MAX_UPLOADS_PER_IP=10
# PLIK_MAX_UPLOADS_PER_USER=50
